    "libsodium-wrappers": "0.7.15",
    "ws": "8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@turbostarter/eslint-config": "workspace:*",
    "@turbostarter/prettier-config": "workspace:*",
    "@turbostarter/tsconfig": "workspace:*",
    "@types/libsodium-wrappers": "0.7.14",
    "@types/ws": "8.5.13",
    "eslint": "catalog:",
